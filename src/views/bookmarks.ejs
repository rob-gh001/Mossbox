<div class="card">
  <h2>Bookmarks</h2>
  <form method="post" action="/api/bookmarks">
    <input type="url" name="url" placeholder="https://example.com" required />
    <input type="text" name="title" placeholder="Optional title" />
    <textarea name="note" rows="3" placeholder="Optional note"></textarea>
    <button type="submit">Save bookmark</button>
  </form>
</div>
<div class="card">
  <h3>Saved bookmarks</h3>
  <div class="list">
    <% bookmarks.forEach(item => { %>
      <div class="item">
        <div><strong><%= item.title || item.fetched_title || item.url %></strong></div>
        <div><a href="<%= item.url %>" target="_blank" rel="noreferrer"><%= item.url %></a></div>
        <% if (item.note) { %><div><%= item.note %></div><% } %>
        <div class="muted"><%= item.created_at %></div>
      </div>
    <% }) %>
  </div>
</div>
