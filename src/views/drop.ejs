<div class="card">
  <h2>Drop</h2>
  <form method="post" action="/drop/upload" enctype="multipart/form-data">
    <input type="file" name="file" required />
    <button type="submit">Upload</button>
  </form>
  <p class="muted">Web download uses session auth. API access uses `Authorization: Bearer &lt;API_KEY&gt;`.</p>
</div>
<div class="card">
  <h3>Recent files</h3>
  <div class="list">
    <% files.forEach(file => { %>
      <div class="item">
        <div><strong><%= file.original_name %></strong></div>
        <div class="muted"><%= file.mime_type || 'unknown' %> · <%= file.size_bytes %> bytes · <%= file.created_at %></div>
        <div class="muted">Web URL:</div>
        <pre>/files/<%= file.id %></pre>
        <div class="muted">API metadata:</div>
        <pre>/api/files/<%= file.id %></pre>
        <div class="muted">API content:</div>
        <pre>/api/files/<%= file.id %>/content</pre>
        <div class="row">
          <div><a href="/files/<%= file.id %>">Download</a></div>
          <form class="inline-form" method="post" action="/drop/<%= file.id %>/delete" onsubmit="return confirm('Delete this file?');">
            <button type="submit">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
    <% if (files.length === 0) { %>
      <div class="item muted">No uploaded files yet.</div>
    <% } %>
  </div>
</div>
