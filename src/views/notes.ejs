<div class="card">
  <h2>Notes</h2>
  <form method="post" action="/api/notes">
    <div class="row">
      <div>
        <label>Type</label>
        <select name="type">
          <option value="note">Note</option>
          <option value="todo">Todo</option>
        </select>
      </div>
    </div>
    <textarea name="content" rows="4" placeholder="Write a note or todo..." required></textarea>
    <button type="submit">Save</button>
  </form>
</div>
<div class="card">
  <h3>Recent entries</h3>
  <div class="list">
    <% notes.forEach(note => { %>
      <div class="item">
        <div><strong><%= note.type.toUpperCase() %></strong> <% if (note.type === 'todo') { %>· <%= note.is_done ? 'DONE' : 'OPEN' %><% } %></div>
        <div><%= note.content %></div>
        <div class="muted"><%= note.created_at %></div>
        <% if (note.type === 'todo') { %>
          <form class="inline-form" method="post" action="/api/notes/<%= note.id %>/toggle">
            <button type="submit"><%= note.is_done ? 'Mark open' : 'Mark done' %></button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>
